# ─────────────────────────────────────────────────────────────────────────────
# K-KUT environment variable template
# Copy this file to .env.local and fill in real values for local development.
# NEVER commit .env.local or any file containing real secrets.
#
# In Vercel: add these under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required — build will fail without these) ──────────────────────
# Found in: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ── Supabase service-role key (server-side only — keep secret) ───────────────
# Only needed for server-side admin operations (e.g. scripts/build-audio-manifest.mjs).
# DO NOT expose this to the browser. Do NOT prefix with NEXT_PUBLIC_.
# Found in: Supabase Dashboard → Project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
